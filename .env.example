# Copy to .env.local and fill in. Both are optional — the app falls back to
# bundled sample recipes if Supabase is not configured.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Seed script only (never commit a service role key):
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATA_FILE=./heritage_kitchen_recipes.json
